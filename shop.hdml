<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=JetBrains+Mono:wght@500;700&amp;family=Space+Grotesk:wght@600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .pixel-bevel {
            box-shadow: inset 2px 2px 0px 0px rgba(255,255,255,0.1), inset -2px -2px 0px 0px rgba(0,0,0,0.4);
        }
        .pixel-bevel-active {
            box-shadow: inset -2px -2px 0px 0px rgba(255,255,255,0.1), inset 2px 2px 0px 0px rgba(0,0,0,0.4);
        }
        .glass-panel {
            background: rgba(20, 18, 24, 0.8);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(207, 188, 255, 0.1);
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-surface": "#e6e0e9",
                        "error-container": "#93000a",
                        "on-tertiary-fixed": "#241a00",
                        "inverse-primary": "#6750a4",
                        "on-error": "#690005",
                        "inverse-on-surface": "#322f35",
                        "surface-container-low": "#1d1b20",
                        "outline-variant": "#494551",
                        "on-primary": "#381e72",
                        "error": "#ffb4ab",
                        "surface-tint": "#cfbcff",
                        "primary-fixed": "#e9ddff",
                        "tertiary": "#e7c365",
                        "primary": "#cfbcff",
                        "on-background": "#e6e0e9",
                        "surface-dim": "#141218",
                        "surface-container-lowest": "#0f0d13",
                        "surface-container-highest": "#36343a",
                        "on-secondary": "#342b4b",
                        "on-primary-fixed-variant": "#4f378a",
                        "outline": "#948e9c",
                        "inverse-surface": "#e6e0e9",
                        "primary-container": "#6750a4",
                        "tertiary-fixed-dim": "#e7c365",
                        "on-tertiary-fixed-variant": "#594400",
                        "tertiary-fixed": "#ffdf93",
                        "on-secondary-fixed": "#1f1635",
                        "on-secondary-container": "#bfb2da",
                        "on-error-container": "#ffdad6",
                        "secondary-fixed-dim": "#cdc0e9",
                        "on-surface-variant": "#cbc4d2",
                        "surface-variant": "#36343a",
                        "primary-fixed-dim": "#cfbcff",
                        "secondary-fixed": "#e9ddff",
                        "secondary-container": "#4d4465",
                        "surface": "#141218",
                        "tertiary-container": "#c9a74d",
                        "surface-container-high": "#2b292f",
                        "on-primary-container": "#e0d2ff",
                        "on-tertiary-container": "#503d00",
                        "secondary": "#cdc0e9",
                        "on-secondary-fixed-variant": "#4b4263",
                        "background": "#141218",
                        "on-primary-fixed": "#22005d",
                        "surface-container": "#211f24",
                        "surface-bright": "#3b383e",
                        "on-tertiary": "#3e2e00"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "margin-edge": "32px",
                        "pixel-step": "4px",
                        "gutter": "16px",
                        "unit": "4px",
                        "panel-padding": "24px"
                    },
                    "fontFamily": {
                        "label-tech": ["JetBrains Mono"],
                        "headline-md": ["Space Grotesk"],
                        "body-lg": ["Inter"],
                        "headline-lg": ["Space Grotesk"],
                        "body-md": ["Inter"],
                        "label-pixel-sm": ["JetBrains Mono"],
                        "display-pixel": ["Space Grotesk"]
                    },
                    "fontSize": {
                        "label-tech": ["14px", {"lineHeight": "20px", "letterSpacing": "0.02em", "fontWeight": "500"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "label-pixel-sm": ["12px", {"lineHeight": "16px", "fontWeight": "700"}],
                        "display-pixel": ["48px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "700"}]
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background text-on-surface font-body-md min-h-screen selection:bg-primary selection:text-on-primary">
<!-- Background Layer: High-Tech Vending Stall -->
<div class="fixed inset-0 z-0">
<img class="w-full h-full object-cover opacity-30 grayscale brightness-50" data-alt="An interior of a high-tech pixel-art inspired vending stall. Dark industrial metal walls are lined with glowing neon pipes in cyan and magenta. Floating holographic displays show data streams and silhouettes of survival gear. The lighting is moody and cinematic with a mix of industrial gloom and futuristic neon hope." src="https://lh3.googleusercontent.com/aida-public/AB6AXuB27a5yLY3A3wabCOPkyICosgwj5_slpHdDHZtYxGZAZhe0Coadg8sqhpOU1pnY97EEJ78lPshdqnDQxJExRKsmLnuzD8inD59GmUkFt5rc_vyAylzs8L2qXDQoCkYP7cwB2YamTzeAKsaravZYub_SrW-aCVG5D1tVVlcFw5mcy_0TB_XjJSjpKl9iaF2KbRcgQwHvbzodqyyCE2-R3IJdhOfUE_ktspvvSCa-QSNbby9mAEewSl_mu1f-mfgW9FkpniNBvg3V2MvI"/>
<div class="absolute inset-0 bg-gradient-to-b from-background/40 via-transparent to-background"></div>
</div>
<!-- Top Navigation Bar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-edge py-unit bg-surface-container/80 dark:bg-surface-container-low/80 backdrop-blur-xl border-b-2 border-outline-variant dark:border-outline">
<div class="flex items-center gap-4">
<span class="font-display-pixel text-headline-md text-primary dark:text-surface-tint tracking-tighter">EcoPixel RPG</span>
<div class="h-6 w-px bg-outline-variant"></div>
<div class="flex items-center gap-2 px-3 py-1 bg-surface-container-highest rounded-lg border border-outline-variant">
<span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">monetization_on</span>
<span class="font-label-tech text-label-tech text-tertiary-fixed">2,450 COINS</span>
</div>
</div>
<div class="flex items-center gap-6">
<nav class="hidden md:flex items-center gap-8">
<button class="font-label-tech text-label-tech text-on-surface-variant opacity-70 hover:bg-primary-container/20 transition-colors px-3 py-1 rounded">World Map</button>
<button class="font-label-tech text-label-tech text-primary dark:text-primary-fixed font-bold border-b-2 border-primary">Shop</button>
<button class="font-label-tech text-label-tech text-on-surface-variant opacity-70 hover:bg-primary-container/20 transition-colors px-3 py-1 rounded">Inventory</button>
</nav>
<div class="flex items-center gap-3">
<div class="flex items-center bg-surface-container rounded-lg border border-outline-variant overflow-hidden">
<button class="px-3 py-1 bg-primary text-on-primary font-label-tech text-[12px]">EN</button>
<button class="px-3 py-1 font-label-tech text-[12px] text-on-surface-variant hover:bg-surface-variant">TH</button>
</div>
<button class="p-2 hover:bg-primary-container/20 rounded-full transition-colors">
<span class="material-symbols-outlined text-on-surface">account_circle</span>
</button>
<button class="p-2 hover:bg-primary-container/20 rounded-full transition-colors">
<span class="material-symbols-outlined text-on-surface">settings</span>
</button>
</div>
</div>
</header>
<!-- Main Content Area -->
<main class="relative z-10 pt-24 pb-32 px-margin-edge max-w-7xl mx-auto">
<!-- Shop Header -->
<div class="mb-12">
<h1 class="font-headline-lg text-headline-lg text-primary mb-2">NEON-VALVE TRADING POST</h1>
<p class="text-on-surface-variant font-body-md max-w-2xl">Survival in the smog isn't cheap, scientist. Upgrade your gear or purge your lungs before the next pixel-storm hits.</p>
</div>
<div class="grid grid-cols-12 gap-gutter">
<!-- Category Sidebar -->
<aside class="col-span-12 md:col-span-3 flex flex-col gap-4">
<div class="glass-panel p-panel-padding rounded-xl flex flex-col gap-2">
<h3 class="font-label-tech text-label-tech text-primary uppercase tracking-widest mb-4">Categories</h3>
<button class="flex items-center gap-4 px-4 py-3 bg-secondary-container text-on-secondary-container rounded-lg border-l-4 border-primary pixel-bevel">
<span class="material-symbols-outlined">masks</span>
<span class="font-label-tech text-label-tech">Masks</span>
</button>
<butto


<a href="game over.html">
  <button>Finish Game</button>
</a>


<div id="mapButton">
  🗺️ Map
</div>