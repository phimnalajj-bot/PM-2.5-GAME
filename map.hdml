<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-surface": "#e6e0e9",
                        "error-container": "#93000a",
                        "on-tertiary-fixed": "#241a00",
                        "inverse-primary": "#6750a4",
                        "on-error": "#690005",
                        "inverse-on-surface": "#322f35",
                        "surface-container-low": "#1d1b20",
                        "outline-variant": "#494551",
                        "on-primary": "#381e72",
                        "error": "#ffb4ab",
                        "surface-tint": "#cfbcff",
                        "primary-fixed": "#e9ddff",
                        "tertiary": "#e7c365",
                        "primary": "#cfbcff",
                        "on-background": "#e6e0e9",
                        "surface-dim": "#141218",
                        "surface-container-lowest": "#0f0d13",
                        "surface-container-highest": "#36343a",
                        "on-secondary": "#342b4b",
                        "on-primary-fixed-variant": "#4f378a",
                        "outline": "#948e9c",
                        "inverse-surface": "#e6e0e9",
                        "primary-container": "#6750a4",
                        "tertiary-fixed-dim": "#e7c365",
                        "on-tertiary-fixed-variant": "#594400",
                        "tertiary-fixed": "#ffdf93",
                        "on-secondary-fixed": "#1f1635",
                        "on-secondary-container": "#bfb2da",
                        "on-error-container": "#ffdad6",
                        "secondary-fixed-dim": "#cdc0e9",
                        "on-surface-variant": "#cbc4d2",
                        "surface-variant": "#36343a",
                        "primary-fixed-dim": "#cfbcff",
                        "secondary-fixed": "#e9ddff",
                        "secondary-container": "#4d4465",
                        "surface": "#141218",
                        "tertiary-container": "#c9a74d",
                        "surface-container-high": "#2b292f",
                        "on-primary-container": "#e0d2ff",
                        "on-tertiary-container": "#503d00",
                        "secondary": "#cdc0e9",
                        "on-secondary-fixed-variant": "#4b4263",
                        "background": "#141218",
                        "on-primary-fixed": "#22005d",
                        "surface-container": "#211f24",
                        "surface-bright": "#3b383e",
                        "on-tertiary": "#3e2e00"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "margin-edge": "32px",
                        "pixel-step": "4px",
                        "gutter": "16px",
                        "unit": "4px",
                        "panel-padding": "24px"
                    },
                    "fontFamily": {
                        "label-tech": ["JetBrains Mono"],
                        "headline-md": ["Space Grotesk"],
                        "body-lg": ["Inter"],
                        "headline-lg": ["Space Grotesk"],
                        "body-md": ["Inter"],
                        "label-pixel-sm": ["JetBrains Mono"],
                        "display-pixel": ["Space Grotesk"]
                    },
                    "fontSize": {
                        "label-tech": ["14px", {"lineHeight": "20px", "letterSpacing": "0.02em", "fontWeight": "500"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "label-pixel-sm": ["12px", {"lineHeight": "16px", "fontWeight": "700"}],
                        "display-pixel": ["48px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "700"}]
                    }
                },
            },
        }
    </script>
<style>
        .pixel-bevel {
            box-shadow: inset 2px 2px 0px 0px rgba(255,255,255,0.1), inset -2px -2px 0px 0px rgba(0,0,0,0.5);
        }
        .pixel-border-neon {
            border: 1px solid #cfbcff;
            box-shadow: 0 0 8px #6750a4;
        }
        .scanline-grid {
            background-image: linear-gradient(rgba(207, 188, 255, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(207, 188, 255, 0.05) 1px, transparent 1px);
            background-size: 32px 32px;
        }
        .hotspot-pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .7; transform: scale(1.1); }
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body-md overflow-hidden">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-edge py-unit bg-surface-container/80 dark:bg-surface-container-low/80 backdrop-blur-xl border-b-2 border-outline-variant dark:border-outline">
<div class="flex items-center gap-4">
<span class="font-display-pixel text-headline-md text-primary dark:text-surface-tint tracking-tighter">EcoPixel RPG</span>
<div class="hidden md:flex gap-6 ml-8">
<button class="font-label-tech text-label-tech text-primary dark:text-primary-fixed font-bold active:scale-95 transition-transform duration-100">World Map</button>
<button class="font-label-tech text-label-tech text-on-surface-variant dark:text-on-surface-variant opacity-70 hover:bg-primary-container/20 dark:hover:bg-primary-container/40 transition-colors px-3 py-1 rounded">Missions</button>
<button class="font-label-tech text-label-tech text-on-surface-variant dark:text-on-surface-variant opacity-70 hover:bg-primary-container/20 dark:hover:bg-primary-container/40 transition-colors px-3 py-1 rounded">Inventory</button>
</div>
</div>
<div class="flex items-center gap-4">
<div class="flex bg-surface-container-highest rounded-lg p-1 border border-outline-variant">
<button class="px-2 py-1 text-label-pixel-sm font-label-pixel-sm bg-primary text-on-primary rounded">EN</button>
<button class="px-2 py-1 text-label-pixel-sm font-label-pixel-sm text-on-surface-variant">TH</button>
</div>
<button class="p-2 hover:bg-primary-container/20 rounded-full transition-colors">
<span class="material-symbols-outlined text-primary">settings</span>
</button>
<button class="p-2 hover:bg-primary-container/20 rounded-full transition-colors">
<span class="material-symbols-outlined text-primary">account_circle</span>
</button>
</div>
</header>
<!-- SideNavBar (Hidden on Mobile) -->
<nav class="hidden md:flex fixed left-0 top-0 h-full z-40 flex-col py-panel-padding w-64 bg-surface-container-highest/90 dark:bg-surface-container-lowest/90 backdrop-blur-2xl border-r-2 border-outline-variant shadow-2xl dark:shadow-none mt-16">
<div class="px-6 mb-8 flex items-center gap-3">
<div class="w-12 h-12 rounded-lg bg-secondary-container flex items-center justify-center border-2 border-primary">
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">person</span>
</div>
<div>
<h3 class="font-headline-sm text-headline-sm text-on-surface leading-tight">Scientist</h3>
<p class="font-body-md text-label-tech text-primary opacity-80">Level 12 Eco-Guardian</p>
</div>
</div>
<div class="flex-1 flex flex-col gap-2">
<a class="bg-secondary-container text-on-secondary-container dark:bg-secondary dark:text-on-secondary border-l-4 border-primary px-4 py-3 mx-2 rounded-lg flex items-center gap-3 translate-x-1 duration-150" href="#">
<span class="material-symbols-outlined">map</span>
<span class="font-body-md">World Map</span>
</a>
<a class="text-on-surface-variant dark:text-on-surface-variant px-4 py-3 mx-2 hover:bg-surface-variant/50 transition-all duration-200 flex items-center gap-3 rounded-lg" href="#">
<span class="material-symbols-outlined">inventory_2</span>
<span class="font-body-md">Inventory</span>
</a>
<a class="text-on-surface-variant dark:text-on-surface-variant px-4 py-3 mx-2 hover:bg-surface-variant/50 transition-all duration-200 flex items-center gap-3 rounded-lg" href="#">
<span class="material-symbols-outlined">assignment</span>
<span class="font-body-md">Missions</span>
</a>
<a class="text-on-surface-variant dark:text-on-surface-variant px-4 py-3 mx-2 hover:bg-surface-variant/50 transition-all duration-200 flex items-center gap-3 rounded-lg" href="#">
<span class="material-symbols-outlined">analytics</span>
<span class="font-body-md">Database</span>
</a>
</div>
<div class="px-4 mt-auto">
<button class="w-full py-4 bg-primary text-on-primary font-bold rounded-xl p

<a href="city map.html">
  <button>Open City Map</button>
</a>