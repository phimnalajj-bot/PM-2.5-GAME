<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@400;500;600&amp;family=JetBrains+Mono:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "tertiary-container": "#c9a74d",
                    "tertiary": "#e7c365",
                    "secondary-fixed-dim": "#cdc0e9",
                    "on-tertiary": "#3e2e00",
                    "surface": "#141218",
                    "on-secondary-container": "#bfb2da",
                    "on-secondary-fixed": "#1f1635",
                    "surface-container-lowest": "#0f0d13",
                    "on-error-container": "#ffdad6",
                    "primary-container": "#6750a4",
                    "surface-dim": "#141218",
                    "outline-variant": "#494551",
                    "primary": "#cfbcff",
                    "on-tertiary-fixed": "#241a00",
                    "inverse-primary": "#6750a4",
                    "secondary": "#cdc0e9",
                    "error": "#ffb4ab",
                    "on-primary": "#381e72",
                    "on-secondary-fixed-variant": "#4b4263",
                    "on-surface-variant": "#cbc4d2",
                    "on-tertiary-fixed-variant": "#594400",
                    "on-error": "#690005",
                    "error-container": "#93000a",
                    "primary-fixed-dim": "#cfbcff",
                    "background": "#141218",
                    "tertiary-fixed": "#ffdf93",
                    "surface-container": "#211f24",
                    "secondary-fixed": "#e9ddff",
                    "surface-variant": "#36343a",
                    "tertiary-fixed-dim": "#e7c365",
                    "on-tertiary-container": "#503d00",
                    "on-surface": "#e6e0e9",
                    "surface-container-high": "#2b292f",
                    "on-background": "#e6e0e9",
                    "on-primary-fixed": "#22005d",
                    "surface-container-low": "#1d1b20",
                    "on-primary-container": "#e0d2ff",
                    "on-primary-fixed-variant": "#4f378a",
                    "inverse-on-surface": "#322f35",
                    "secondary-container": "#4d4465",
                    "outline": "#948e9c",
                    "on-secondary": "#342b4b",
                    "surface-container-highest": "#36343a",
                    "surface-bright": "#3b383e",
                    "primary-fixed": "#e9ddff",
                    "surface-tint": "#cfbcff",
                    "inverse-surface": "#e6e0e9"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "spacing": {
                    "panel-padding": "24px",
                    "unit": "4px",
                    "margin-edge": "32px",
                    "pixel-step": "4px",
                    "gutter": "16px"
            },
            "fontFamily": {
                    "headline-lg": ["Space Grotesk"],
                    "body-md": ["Inter"],
                    "label-pixel-sm": ["JetBrains Mono"],
                    "label-tech": ["JetBrains Mono"],
                    "display-pixel": ["Space Grotesk"],
                    "body-lg": ["Inter"],
                    "headline-md": ["Space Grotesk"]
            },
            "fontSize": {
                    "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                    "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "label-pixel-sm": ["12px", {"lineHeight": "16px", "fontWeight": "700"}],
                    "label-tech": ["14px", {"lineHeight": "20px", "letterSpacing": "0.02em", "fontWeight": "500"}],
                    "display-pixel": ["48px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "700"}],
                    "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                    "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .pixel-border-inset {
            box-shadow: inset 2px 2px 0px 0px rgba(255,255,255,0.1), inset -2px -2px 0px 0px rgba(0,0,0,0.4);
        }
        .pixel-border-glow {
            border: 2px solid theme('colors.primary');
            box-shadow: 0 0 15px theme('colors.primary-container');
        }
        .glass-panel {
            background: rgba(20, 18, 24, 0.8);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(207, 188, 255, 0.1);
        }
        .scanline {
            background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.1) 50%);
            background-size: 100% 4px;
        }
    </style>
</head>
<body class="bg-background text-on-surface min-h-screen overflow-hidden font-body-md selection:bg-primary selection:text-on-primary">
<!-- Top App Bar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-start px-margin-edge pt-panel-padding">
<div class="flex flex-col gap-1">
<h1 class="font-display-pixel text-headline-lg text-primary uppercase tracking-widest leading-none">EcoPixel RPG</h1>
<div class="flex items-center gap-2 bg-surface-container-high/60 backdrop-blur-md px-3 py-1 rounded-sm border-l-4 border-tertiary">
<span class="material-symbols-outlined text-tertiary text-[20px]" data-icon="token">token</span>
<span class="font-label-tech text-on-surface">COINS: <span class="text-tertiary">14,250</span></span>
</div>
</div>
<div class="flex gap-4">
<button class="bg-surface-container-high/60 backdrop-blur-md p-2 hover:text-tertiary transition-colors active:scale-95 text-primary">
<span class="material-symbols-outlined" data-icon="map">map</span>
</button>
<button class="bg-surface-container-high/60 backdrop-blur-md p-2 hover:text-tertiary transition-colors active:scale-95 text-primary">
<span class="material-symbols-outlined" data-icon="notifications_active">notifications_active</span>
</button>
</div>
</header>
<!-- Main Content: Gacha Terminal -->
<main class="relative h-screen w-full flex items-center justify-center pt-24 pb-32">
<!-- Background World Glimpse -->
<div class="absolute inset-0 z-0">
<img alt="Cyberpunk Cityscape" class="w-full h-full object-cover opacity-20" data-alt="A sprawling pixel-art cityscape at night, heavily inspired by retro 16-bit games. Neon purple and teal lights flicker across rain-slicked industrial structures and high-tech scaffolds. The atmosphere is dense with smog and digital distortion, creating a moody, atmospheric environmental backdrop with high-contrast shadows and glowing technological focal points." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlN8eFboETTGa35OQPuo_9d7-J59tDxO8c-0ClY211xGoUQa5I2wL_BvhE4YRWiTvppDUS0qVZinrihWQxgjniFslty-0YFAybEkSgO6I38lET9Wn81qk8yi5R_BgXpbIOoXjOHJGy3hQPCx04aFhLIZcBtYybX-ypaqXpnbDewoDDD-DmbvF4xQgemBu5KhPxp1iILrP3sNDVK8aib-0Cc9A_pVafPbXh8xH-BdG3YChTkAkj7NUvjC0IOkKdauGeSx3vbStzLZTj"/>
<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/50"></div>
<div class="absolute inset-0 scanline opacity-10"></div>
</div>
<div class="relative z-10 w-full max-w-6xl grid grid-cols-1 lg:grid-cols-12 gap-gutter px-margin-edge">
<!-- Left Side: Probabilities & Rewards Preview -->
<div class="lg:col-span-4 flex flex-col gap-gutter">
<div class="glass-panel p-panel-padding border-l-4 border-primary">
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-primary" data-icon="auto_awesome">auto_awesome</span>
<h2 class="font-headline-md text-primary uppercase tracking-tight">Available Rewards</h2>
</div>
<div class="space-y-3">
<!-- Reward Item -->
<div class="flex items-center gap-4 bg-surface-container/50 p-3 pixel-border-inset hover:bg-surface-container-highest transition-colors group">
<div class="w-12 h-12 bg-surface-container-highest flex items-center justify-center border-2 border-outline-variant group-hover:border-primary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary" data-icon="mask">masks</span>
</div>
<div class="flex-1">
<div class="font-label-tech text-on-surface">Rare Gas Mask</div>
<div class="text-[10px] font-label-pixel-sm text-primary uppercase">Elite Tier</div>
</div>
<div class="text-tertiary font-label-tech">0.5%</div>
</div>
<div class="flex items-center gap-4 bg-surface-container/50 p-3 pixel-border-inset hover:bg-surface-container-highest transition-colors group">
<div class="w-12 h-12 bg-surface-container-highest flex items-center justify-center border-2 border-outline-variant group-hover:border-secondary transition-colors">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-secondary" data-icon="person_search">person_search</span>
</div>
<div class="flex-1">
<div class="font-label-tech text-on-surface">Researcher Skin</div>
<div class="text-[10px] font-label-pixel-sm text-secondary uppercase">Epic Tier</div>
</div>
<div class="text-tertiary font-label-tech">2.5%</div>
</div>
<div class=
<a href="1home.html">
  <button>Enter Home</button>
</a>